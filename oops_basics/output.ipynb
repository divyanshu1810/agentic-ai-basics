   ],
   "source": [
    "s = \"hello\"\n",
    "s = list(s)\n",
    "\n",
    "left, right = 0, len(s) - 1\n",
    "\n",
    "while left < right:\n",
    "    s[left], s[right] = s[right], s[left]\n",
    "    left += 1\n",
    "    right -= 1\n",
    "\n",
    "print(\"\".join(s))  # olleh"
   ]
  },
